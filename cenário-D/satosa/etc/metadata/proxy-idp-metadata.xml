<?xml version="1.0" encoding="UTF-8"?>
<!--
     Metadata local do proxy de identidade (SATOSA) atuando como IdP
     perante o SP real (cenário D - agregação pelo proxy).
     Gerada localmente para este laboratório; não faz parte do
     agregado real da federação GIdLab.
-->
<EntityDescriptor xmlns="urn:oasis:names:tc:SAML:2.0:metadata"
    xmlns:ds="http://www.w3.org/2000/09/xmldsig#"
    entityID="https://proxy-wgid.gidlab.rnp.br/Saml2IDP/proxy.xml">
    <IDPSSODescriptor protocolSupportEnumeration="urn:oasis:names:tc:SAML:2.0:protocol">
        <KeyDescriptor use="signing">
            <ds:KeyInfo>
                <ds:X509Data>
                    <ds:X509Certificate></ds:X509Certificate>
                </ds:X509Data>
            </ds:KeyInfo>
        </KeyDescriptor>
        <!-- O SATOSA registra os endpoints de SSO do frontend usando o
             nome do BACKEND no path (não o nome do frontend) - ver
             satosa.frontends.saml2.SAMLFrontend._register_endpoints -->
        <SingleSignOnService Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Redirect"
            Location="https://proxy-wgid.gidlab.rnp.br/Saml2/sso/redirect" />
        <SingleSignOnService Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
            Location="https://proxy-wgid.gidlab.rnp.br/Saml2/sso/post" />
    </IDPSSODescriptor>
    <Organization>
        <OrganizationName xml:lang="pt-BR">GIdLab</OrganizationName>
        <OrganizationDisplayName xml:lang="pt-BR">GIdLab - Proxy de Identidade (Cenário D)</OrganizationDisplayName>
        <OrganizationURL xml:lang="pt-BR">https://proxy-wgid.gidlab.rnp.br</OrganizationURL>
    </Organization>
    <ContactPerson contactType="technical">
        <GivenName>GIdLab</GivenName>
        <EmailAddress>gidlab@rnp.br</EmailAddress>
    </ContactPerson>
</EntityDescriptor>
