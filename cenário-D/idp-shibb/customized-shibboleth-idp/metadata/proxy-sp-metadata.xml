<?xml version="1.0" encoding="UTF-8"?>
<!--
     Metadata local do proxy de identidade (SATOSA) atuando como SP
     perante o IdP/Shibboleth real (cenário D - agregação pelo proxy).
     Gerada localmente para este laboratório; não faz parte do
     agregado real da federação GIdLab.
-->
<EntityDescriptor xmlns="urn:oasis:names:tc:SAML:2.0:metadata"
    xmlns:ds="http://www.w3.org/2000/09/xmldsig#"
    entityID="https://proxy-wgid.gidlab.rnp.br/Saml2/proxy_saml2_backend.xml">
    <SPSSODescriptor AuthnRequestsSigned="true" WantAssertionsSigned="true"
        protocolSupportEnumeration="urn:oasis:names:tc:SAML:2.0:protocol">
        <KeyDescriptor use="signing">
            <ds:KeyInfo>
                <ds:X509Data>
                    <ds:X509Certificate></ds:X509Certificate>
                </ds:X509Data>
            </ds:KeyInfo>
        </KeyDescriptor>
        <KeyDescriptor use="encryption">
            <ds:KeyInfo>
                <ds:X509Data>
                    <ds:X509Certificate></ds:X509Certificate>
                </ds:X509Data>
            </ds:KeyInfo>
        </KeyDescriptor>
        <NameIDFormat>urn:oasis:names:tc:SAML:2.0:nameid-format:transient</NameIDFormat>
        <AssertionConsumerService Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
            Location="https://proxy-wgid.gidlab.rnp.br/Saml2/acs/post" index="1" isDefault="true" />
    </SPSSODescriptor>
    <Organization>
        <OrganizationName xml:lang="pt-BR">GIdLab</OrganizationName>
        <OrganizationDisplayName xml:lang="pt-BR">GIdLab - Proxy de Identidade (Cenário D)</OrganizationDisplayName>
        <OrganizationURL xml:lang="pt-BR">https://proxy-wgid.gidlab.rnp.br</OrganizationURL>
    </Organization>
    <ContactPerson contactType="technical">
        <GivenName>GIdLab</GivenName>
        <EmailAddress>gidlab@rnp.br</EmailAddress>
    </ContactPerson>
</EntityDescriptor>
